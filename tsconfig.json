{
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ],
  "exclude": [
    "src/**/__tests__/*"
  ],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "composite": true,
    "lib": [],
    "types": [
      "node",
      "jsdom"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
}
